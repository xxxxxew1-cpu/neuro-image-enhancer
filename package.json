{
  "name": "neuro-image-enhancer",
  "version": "1.0.0",
  "description": "In-browser, real-time image enhancement (brightness/contrast/color) powered by a TensorFlow.js model running in a Web Worker.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "train": "node training/train.mjs",
    "size": "node scripts/check-size.mjs",
    "e2e": "node scripts/e2e.mjs"
  },
  "dependencies": {
    "@tensorflow/tfjs-backend-cpu": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "@tensorflow/tfjs-layers": "^4.22.0",
    "heic-to": "^1.5.2"
  },
  "devDependencies": {
    "playwright": "^1.61.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
